# ===========================================================================
# Plantilla de configuracion - Proceso de Portabilidad
# ---------------------------------------------------------------------------
# Copia este archivo a .env y rellena los valores reales:
#     cp .env.example .env
# El .env real esta en .gitignore y NO debe versionarse (contiene secretos).
# ===========================================================================

# ---------------------------------------------------------------------------
# Activacion de notificaciones (true/false)
# ---------------------------------------------------------------------------
NOTIFY_START=true
NOTIFY_END=true
NOTIFY_ERROR=true

# ---------------------------------------------------------------------------
# Notificaciones por correo (SMTP)
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=25
# Autenticacion SMTP (dejar vacio si el servidor no la requiere)
SMTP_USER=
SMTP_PASSWORD=
# Usar STARTTLS (true/false)
SMTP_TLS=false
# Remitente (obligatorio si alguna NOTIFY_* esta activa)
MAIL_FROM=usuario@example.com
# Destinatarios separados por coma (obligatorio si alguna NOTIFY_* esta activa)
MAIL_TO=usuario@example.com

# ===========================================================================
# CONEXIONES: hay 3 independientes, cada una a su propio servidor/puerto/usuario
#   1) EMS_CLI  : sesion pexpect que ejecuta los comandos put/delete (SSH_*/CLI_*)
#   2) SCP      : copia de los archivos de comandos al servidor destino (SCP_*)
#   3) RECOVERY : accion correctiva/reboot tras agotar reintentos (RECOVERY_SSH_*)
# ===========================================================================
# ---------------------------------------------------------------------------
# Conexion 1: EMS_CLI (sesion pexpect que ejecuta los comandos put/delete)
# ---------------------------------------------------------------------------
# Host de la consola CLI del EMS
SSH_HOST=192.0.2.10
# Puerto de la SESION CLI del EMS (ssh interactivo a la consola SONUS/EMS). En
# estos equipos suele ser un puerto PROPIO de la CLI (p. ej. 8122), distinto del
# SSH del sistema operativo por el que viaja el scp de archivos (ver SCP_PORT).
SSH_PORT=8122
# Usuario de la sesion CLI (ssh). Se fuerza con 'ssh -o User=' por encima de
# cualquier ~/.ssh/config del usuario que corra el proceso (p. ej. airflow), asi
# la sesion SIEMPRE se abre con este usuario y nunca con otro.
SSH_USER=CHANGE_ME
# Password del CLI que se envia dentro de la sesion
CLI_PASSWORD=CHANGE_ME
# Instancia destino en el CLI
CLI_INSTANCE=CHANGE_ME
# Prefijo de los nombres de archivo y del batch_script remoto.
# Los archivos se llaman <FILE_PREFIX>_<TYPE>_<fecha>[_<parte>].csv y el equipo
# ejecuta 'execute batch_script <FILE_PREFIX>_...'. Debe coincidir con el nombre
# que espera el equipo.
FILE_PREFIX=CHANGE_ME

# ---------------------------------------------------------------------------
# Conexion 2: SCP (copia de los archivos de comandos al servidor destino)
# ---------------------------------------------------------------------------
# Es una conexion INDEPENDIENTE de la CLI: puede ir a OTRO servidor. Si SCP_HOST
# se deja vacio, cae a SSH_HOST (caso de un solo servidor donde CLI y scp coinciden).
SCP_HOST=192.0.2.11
# Usuario del scp. Se fuerza con 'scp -o User=' por encima del ~/.ssh/config del
# proceso (p. ej. airflow): pon aqui el usuario deseado y el scp SIEMPRE usara ese.
SCP_USER=CHANGE_ME
# Puerto del scp: es el SSH del SISTEMA OPERATIVO (por defecto 22), NO el de la
# CLI. El scp copia archivos al filesystem del equipo, por eso usa el ssh normal
# y no el puerto de la consola CLI (SSH_PORT). Cambialo solo si tu SO usa otro.
SCP_PORT=22
SCP_DEST_PATH=/ruta/destino/en/el/equipo/
# Modo debug de la sesion CLI (pexpect) y del scp: con true duplica a PANTALLA lo
# que llega del equipo (ademas del log en LOG_DIR/<parte>.csv) y muestra el ssh,
# los comandos enviados a la CLI (el password va enmascarado) y el scp completo.
# Tambien se activa con SYNC_DEBUG=true (mismo switch que el debug del full_sync).
CLI_DEBUG=false

# ---------------------------------------------------------------------------
# Rutas y parametros del proceso
# ---------------------------------------------------------------------------
# Directorio local donde estan/generan los archivos
DIRFILES=/ruta/local/portabilidad
# Directorio para los logs de la sesion CLI
LOG_DIR=/ruta/local/portabilidad/log
# Cantidad de lineas por parte (chunk)
CHUNK_SIZE=20000
# Segundos de espera entre partes
SLEEP_BETWEEN=120

# ---------------------------------------------------------------------------
# Reintentos y reanudacion (resiliencia ante reinicio de conexion)
# ---------------------------------------------------------------------------
# Cantidad de reintentos por parte si falla la conexion/comando (0 = sin reintentos)
SSH_RETRIES=3
# Segundos de espera entre reintentos de una misma parte
RETRY_SLEEP=30
# Directorio de checkpoints (estado de partes completadas). Vacio => usa LOG_DIR.
CHECKPOINT_DIR=

# ---------------------------------------------------------------------------
# Conexion 3: RECOVERY (accion correctiva/reboot tras agotar los reintentos)
# Es un servidor INDEPENDIENTE del de la CLI/scp: define su propio host/puerto/usuario.
# ---------------------------------------------------------------------------
# true/false para activar la accion correctiva cuando una parte agota SSH_RETRIES.
RECOVERY_ENABLED=false
# Los siguientes son obligatorios solo si RECOVERY_ENABLED=true. El host suele ser
# OTRO servidor (no el de la CLI/scp). Requiere clave SSH: el ssh usa BatchMode
# (sin password interactivo).
RECOVERY_SSH_HOST=192.0.2.12
RECOVERY_SSH_PORT=22
RECOVERY_SSH_USER=root
# Comando a ejecutar en el equipo de recuperacion (ej. reboot / systemctl restart ...)
RECOVERY_CMD=reboot
# Segundos de espera tras la accion correctiva
RECOVERY_WAIT=180
# Cuantas veces se permite disparar la accion correctiva antes de abortar la parte
RECOVERY_MAX_CYCLES=1
# Timeout (segundos) para el comando ssh de recuperacion
RECOVERY_TIMEOUT=60

# ---------------------------------------------------------------------------
# Calendario: omitir domingos y dias festivos de Mexico
# ---------------------------------------------------------------------------
SKIP_SUNDAY=true
SKIP_HOLIDAYS=true
# Festivos extra (opcionales) en formato YYYY-MM-DD separados por coma.
EXTRA_HOLIDAYS=
# Que fecha se evalua: run = fecha de ejecucion (hoy) | data = fecha de --date
SKIP_CHECK_DATE=run

# ===========================================================================
# FULL SYNC - Comparacion de bases y generacion de diferencias
# ===========================================================================

# ---------------------------------------------------------------------------
# BD del area de Sistemas (ABD) - Microsoft SQL Server
# ---------------------------------------------------------------------------
ABD_DRIVER=ODBC Driver 18 for SQL Server
ABD_SERVER=192.0.2.20
ABD_DATABASE=CHANGE_ME
ABD_USER=CHANGE_ME
ABD_PASSWORD=CHANGE_ME
# Encrypt: yes/no/optional segun la config del servidor
ABD_ENCRYPT=no

# ---------------------------------------------------------------------------
# BD del equipo PSX - Oracle
# ---------------------------------------------------------------------------
PSX_HOST=192.0.2.30
PSX_PORT=1521
PSX_SID=CHANGE_ME
PSX_USER=CHANGE_ME
PSX_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Constantes del protocolo CLI del equipo (formato de los comandos put/delete)
# ---------------------------------------------------------------------------
# Country_Id / Translated_Country_Id (Mexico = 52)
COUNTRY_ID=52
# Prefijo intercalado en Translated_National_Id: {operator}{TRANSLATED_PREFIX}{num}
TRANSLATED_PREFIX=177
# Valor de Translation_Label_Id en el comando put
TRANSLATION_LABEL_ID=00_TL_dummy

# ---------------------------------------------------------------------------
# Parametros del full_sync
# ---------------------------------------------------------------------------
# Usuario del sistema con el que DEBE correr el full_sync (p. ej. airflow). El
# script NO cambia de usuario: solo verifica y aborta si el proceso no corre como
# este usuario, para no ejecutar por error como root. El cambio de usuario lo hace
# quien lo invoca: Airflow con run_as_user, o 'sudo -u airflow -E python3
# full_sync.py ...'. Vacio => sin verificacion (corre como el usuario actual).
RUN_AS_USER=
# Modo debug: imprime como se conecta a cada BD (usuario/host/puerto/driver/DSN)
# para diagnosticar credenciales/conexion. Los passwords van ENMASCARADOS.
SYNC_DEBUG=false
# Peligroso: con true, el debug imprime los passwords EN CLARO (los logs de
# Airflow/consola quedan persistidos). Usalo solo para un diagnostico puntual.
SYNC_DEBUG_SHOW_SECRETS=false
# Directorio de trabajo para archivos intermedios. Vacio => usa DIRFILES.
SYNC_WORKDIR=
# Mantener (true) o borrar (false) los intermedios abd_*/psx_* al terminar
SYNC_KEEP_INTERMEDIATE=false
# Saltar la descarga de una BD y REUSAR su CSV de una corrida anterior
# (abd.csv/psx.csv en el workdir). Requiere SYNC_KEEP_INTERMEDIATE=true en la
# corrida previa; si el CSV no existe, se aborta.
# SKIP_DB_DOWNLOAD=true salta AMBAS descargas de una sola vez (atajo de
# SKIP_ABD=true + SKIP_PSX=true) para re-comparar sin volver a bajar las BD.
SKIP_DB_DOWNLOAD=false
SKIP_ABD=false
SKIP_PSX=false
# SKIP_COMPARE=true omite TODA la generacion (descarga + troceo + comparacion +
# escritura) y arranca directo en la ejecucion de la portabilidad, reusando los
# CSV PORTED/DELETED de una corrida previa en DIRFILES. Util para reintentar solo
# la ejecucion. Si esos CSV no existen, se aborta. Incompatible con --no-execute.
SKIP_COMPARE=false
# Habilitar (true) o deshabilitar (false) el loteo al procesar
SYNC_BATCH_ENABLED=true
# Loteo base: rango de digitos del primer nivel (inicio-fin, inclusive).
# Debe cubrir TODA la numeracion (por defecto 2..9); reducirlo provoca borrados indebidos.
SYNC_BASE_FROM=2
SYNC_BASE_TO=9
# Profundidad del loteo: 1 => 2..9 | 2 => 20..99 | 3 => 200..999
SYNC_DEPTH=1
# Cada cuantos SEGUNDOS se imprime una linea de progreso al descargar cada BD
# (progreso por tiempo, no por cantidad de filas: ritmo de log constante aunque
# sean decenas de millones de registros). Muestra registros, tiempo y reg/s.
# 0 = sin lineas de progreso (solo el resumen final con registros/peso/tiempo).
SYNC_PROGRESS_SECS=10
