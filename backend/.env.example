# ---------------------------------------------------------------------------
# Backend de portabilidad (BD de tracking + ingesta)
#
# Este backend lee variables de la RAIZ del repo (../.env), que ya contiene las
# credenciales de ABD (MSSQL) y PSX (Oracle) usadas por los scripts Python.
# Aqui solo se AGREGAN las variables propias del backend. En produccion, agrega
# estas lineas al .env de la raiz (o crea backend/.env; se cargan ambos).
# ---------------------------------------------------------------------------

# --- BD de tracking (destino) --------------------------------------------
# Motor de la BD de tracking: "postgresql" o "mysql".
# Al cambiarlo, ajusta DATABASE_URL y corre las migraciones de nuevo.
DB_PROVIDER=postgresql

# Postgres local (por defecto):
DATABASE_URL=postgresql://portabilidad:portabilidad@localhost:5432/portabilidad?schema=public
# MySQL (ejemplo, si DB_PROVIDER=mysql):
# DATABASE_URL=mysql://portabilidad:portabilidad@localhost:3306/portabilidad

# --- Fuente ABD (MSSQL) — reusa el .env de la raiz -----------------------
# ABD_SERVER, ABD_DATABASE, ABD_USER, ABD_PASSWORD, ABD_ENCRYPT ya estan en ../.env

# --- Fuente PSX (Oracle) — reusa el .env de la raiz ----------------------
# PSX_HOST, PSX_PORT, PSX_SID, PSX_USER, PSX_PASSWORD ya estan en ../.env

# --- Ingesta desde CSV ---------------------------------------------------
# Directorio donde full_sync.py deja los CSV (_PORTED/_DELETED). Por defecto
# usa SYNC_WORKDIR/DIRFILES del .env raiz si no se define aqui.
# CSV_DIR=/home/airflow/portabilidad
